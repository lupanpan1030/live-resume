# Admin authentication for later editing phases.
# Leave these empty for the current public resume site.
ADMIN_PASSWORD=
AUTH_SECRET=

# Content store.
# Selection order: Upstash REST, then standard Redis URL, then local file system.
# Without Redis env values, local development reads and writes content/*.json.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=
