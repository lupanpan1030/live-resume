# Admin authentication.
# Set ADMIN_PASSWORD to enable /login and in-page editing.
# Leave ADMIN_PASSWORD empty only when you want a read-only public resume.
ADMIN_PASSWORD=

# Optional explicit JWT signing secret.
# If omitted, the app derives a signing key from ADMIN_PASSWORD.
AUTH_SECRET=

# Content store.
# Selection order: Upstash REST, then standard Redis URL, then local file system.
# Without Redis env values, local development reads and writes content/*.json.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=

# Public site URL for canonical metadata, sitemap, robots, and Open Graph links.
# Example: https://your-domain.com
NEXT_PUBLIC_SITE_URL=
